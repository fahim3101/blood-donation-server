# MongoDB Atlas credentials
DB_USER=your_mongodb_username
DB_PASS=your_mongodb_password
DB_CLUSTER=your_cluster_address.mongodb.net

# JWT secret - generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_long_random_secret_here

# Stripe secret key (from Stripe dashboard, test mode)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

PORT=5000
